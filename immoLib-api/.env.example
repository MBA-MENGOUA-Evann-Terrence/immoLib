# URI Atlas (mongodb+srv) — peut echouer sous Node.js/Windows
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/immoLib?retryWrites=true&w=majority

# Liste des shards pour auto-detection du primaire (nslookup -type=SRV _mongodb._tcp.<cluster>.mongodb.net)
MONGODB_SHARD_HOSTS=ac-xxxxx-shard-00-00.xxxxx.mongodb.net,ac-xxxxx-shard-00-01.xxxxx.mongodb.net,ac-xxxxx-shard-00-02.xxxxx.mongodb.net

# Alternative manuelle : URI directe vers le shard primaire uniquement
# MONGODB_URI_DIRECT=mongodb://<user>:<password>@ac-xxxxx-shard-00-01.xxxxx.mongodb.net:27017/immoLib?ssl=true&authSource=admin&directConnection=true&retryWrites=true&w=majority

DB_NAME=immoLib
PORT=5000
JWT_SECRET=change_moi_par_une_longue_chaine_secrete
FRONTEND_URL=http://localhost:5173
